# 文字生成 / 审核 / 评分：使用你开通的推理模型
ARK_TEXT_MODEL=doubao-seed-2-0-lite-260428

# 图片生成：填写你开通的图片模型或接入点。
# 默认走 /responses；如果你填的是 Seedream 专用模型并希望走 /images/generations，则改成 ARK_IMAGE_API=images
ARK_IMAGE_MODEL=doubao-seedream-4-0-250828
ARK_IMAGE_API=images

# 视频生成：填写你开通的视频模型或接入点
ARK_VIDEO_MODEL=doubao-seed-2-0-lite-260428
ARK_VIDEO_API=responses

# ModelScope 备选（仅火山方舟失败时使用；不需要可留空）
