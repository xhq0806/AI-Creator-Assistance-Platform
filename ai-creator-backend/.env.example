# ============================================================
# AI Creator Platform — 环境配置模板
# ============================================================
# 安全警告：
#   - JWT_SECRET 和 JWT_REFRESH_SECRET 在生产环境必须设置强随机密钥。
#   - 开发环境可使用默认值，生产环境使用默认值将导致启动失败。
#   - 生成强随机密钥：node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
#   - 请勿将此文件提交到版本控制系统，复制为 .env 后修改。
# ============================================================

# ---- 运行模式 ----
NODE_ENV=development
PORT=3000

# ---- JWT 密钥 (生产环境必须修改) ----
JWT_SECRET=replace-with-a-strong-secret-at-least-32-chars
JWT_REFRESH_SECRET=replace-another-strong-secret-at-least-32-chars

# ---- MySQL ----
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=ai_creator
MYSQL_USER=root
MYSQL_PASSWORD=

# ---- Redis ----
REDIS_URL=redis://127.0.0.1:6379

# ---- AI Provider: ark | modelscope ----
AI_TIMEOUT_MS=120000
AI_PROVIDER=ark

# ---- ModelScope (可选备选) ----
MODELSCOPE_API_TOKEN=
MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1
MODELSCOPE_TEXT_MODEL=Qwen/Qwen3-235B-A22B-Instruct-2507
MODELSCOPE_IMAGE_MODEL=Qwen/Qwen-Image

# ---- 火山方舟 Ark (推荐) ----
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_TEXT_MODEL=doubao-seed-2-0-lite-260428
ARK_IMAGE_MODEL=doubao-seedream-4-0-250828
ARK_IMAGE_API=images
ARK_VIDEO_MODEL=
ARK_VIDEO_API=responses

# ---- 云存储: mock | aliyun ----
CLOUD_PROVIDER=mock
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=ai-creator
OSS_REGION=oss-cn-hangzhou
