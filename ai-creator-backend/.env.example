PORT=3000
JWT_SECRET=replace-with-a-strong-secret

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=ai_creator
MYSQL_USER=root
MYSQL_PASSWORD=

REDIS_URL=redis://127.0.0.1:6379

# AI provider: modelscope or ark
AI_TIMEOUT_MS=60000
AI_PROVIDER=modelscope

# ModelScope OpenAI-compatible Chat Completions API
MODELSCOPE_API_TOKEN=
MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1
MODELSCOPE_TEXT_MODEL=Qwen/Qwen3-235B-A22B-Instruct-2507

# Optional Volcengine Ark fallback
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=doubao-seed-1-6-250615

# Cloud storage for material upload: mock or aliyun
CLOUD_PROVIDER=mock
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=ai-creator
OSS_REGION=oss-cn-hangzhou
